{
	"name": "fsapp",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"db:seed": "tsx --env-file=.env scripts/seed.ts",
		"db:seed:demo": "tsx --env-file=.env scripts/seed-demo.ts",
		"db:seed:reset": "tsx --env-file=.env scripts/seed-demo.ts --reset",
		"db:seed:admin": "tsx --env-file=.env scripts/seed-admin.ts",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "latest",
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "latest",
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.14.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22",
		"better-auth": "~1.4.21",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"mode-watcher": "^1.1.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"svelte-sonner": "^1.1.1",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"better-sqlite3": "^12.8.0",
		"resend": "^6.12.2",
		"sonner": "^2.0.7",
		"valibot": "^1.3.1"
	}
}
